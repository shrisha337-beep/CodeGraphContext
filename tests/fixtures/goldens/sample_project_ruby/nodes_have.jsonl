{"_id": {"offset": 4, "table": 4}, "path": "./tests/test_mixins.py", "name": "test_ruby_class_includes_module", "is_dependency": false, "lang": "python", "line_number": 1, "uid": "test_ruby_class_includes_module/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_ruby/tests/test_mixins.py1", "end_line": 16, "source": "def test_ruby_class_includes_module(graph):\n    # Check that the module node exists\n    rows = graph.query('MATCH (:Module {name:\"Flyable\"}) RETURN 1 AS ok LIMIT 1')\n    assert rows, \"Expected a Module node named 'Flyable' but none was found.\"\n\n    # Check that the class node exists\n    rows = graph.query('MATCH (:Class {name:\"Bird\"}) RETURN 1 AS ok LIMIT 1')\n    assert rows, \"Expected a Class node named 'Bird' but none was found.\"\n\n    # Check that the INCLUDES relationship exists between Bird and Flyable\n    rows = graph.query('''\n        MATCH (:Class {name:\"Bird\"})-[:INCLUDES]->(:Module {name:\"Flyable\"})\n        RETURN count(*) AS c\n    ''')\n    assert rows and rows[0][\"c\"] > 0, \\\n        \"Expected an INCLUDES relationship from Class 'Bird' to Module 'Flyable', but none was found.\"", "cyclomatic_complexity": 2, "decorators": [""], "args": ["graph"], "_labels": ["Function"]}
{"_id": {"offset": 5, "table": 4}, "path": "./tests/test_mixins.py", "name": "test_module_is_unique", "is_dependency": false, "lang": "python", "line_number": 19, "uid": "test_module_is_unique/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_ruby/tests/test_mixins.py19", "end_line": 23, "source": "def test_module_is_unique(graph):\n    # Ensure only one Module node named 'Flyable' exists\n    rows = graph.query('MATCH (m:Module {name:\"Flyable\"}) RETURN count(m) AS c')\n    assert rows and rows[0][\"c\"] == 1, \\\n        f\"Expected exactly one Module node named 'Flyable', but found {rows[0]['c'] if rows else 0}.\"", "cyclomatic_complexity": 2, "decorators": [""], "args": ["graph"], "_labels": ["Function"]}
